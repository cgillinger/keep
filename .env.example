# Session secret for cookie encryption
# Generate a random string for production
SESSION_SECRET=change-this-to-a-random-string-in-production

# Port (default: 3000)
PORT=3000

# HTTPS Configuration (default: false)
# Set to 'true' ONLY if running behind HTTPS (reverse proxy with TLS termination, e.g., nginx, Caddy)
# This enables HSTS (HTTP Strict Transport Security) headers
# Leave as 'false' for HTTP deployments (Docker, LAN, Tailscale without HTTPS)
FORCE_HTTPS=false

# Reverse proxy hops to trust (default: 1 when FORCE_HTTPS=true, otherwise off).
# Required behind a reverse proxy so rate limiting keys on the real client IP
# instead of the proxy's — otherwise all users share one bucket. Set to the number
# of proxies in front of the app (usually 1), or 'true' to trust the whole chain.
# TRUST_PROXY=1

# Email Configuration (OPTIONAL - för lösenordsåterställning)
# Om dessa inte är ifyllda, kommer lösenordsåterställning inte vara tillgänglig
# För Gmail: Aktivera 2FA och skapa ett applösenord på https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=din.familj@gmail.com
SMTP_PASS=ditt_applösenord_här
EMAIL_FROM=Keep Clone <din.familj@gmail.com>

# AI-kommandon (//list, //ocr) — kräver Gemini API-nyckel
# Hämta gratis nyckel på https://aistudio.google.com/apikey
AI_COMMANDS_ENABLED=false
GEMINI_API_KEY=your_gemini_api_key
AI_RATE_LIMIT_HOURLY=10
AI_RATE_LIMIT_DAILY=50

# Max images per note (default: 30)
MAX_IMAGES_PER_NOTE=30
